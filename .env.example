# Copy to .env.local and fill in values.

# Optional: SQLite + metadata.json directory (default: ./data). Use an absolute path in Docker if the DB is mounted elsewhere.
# HELP_CENTER_DATA_DIR=/app/data

# Optional: Media files directory. Default: ./public/media (local), or /app/media when cwd is /app (Docker). Override to any path.
# HELP_CENTER_MEDIA_DIR=/app/media

# Optional: Writable directory for site-config.json + search-index.json (default: ./public). Use when the image has no public/ folder (e.g. .dockerignore).
# HELP_CENTER_PUBLIC_DIR=/app/public

# Required for Notion sync (npm run sync)
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Optional: cron expression for automatic Notion sync while `next start` is running (node-cron; server timezone).
# Example: every 6 hours — 0 */6 * * *
# HELP_CENTER_SYNC_CRON=

# Admin UI at /admin (HTTP Basic). If unset, admin routes return 503.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Public URL of this help site (sitemap, absolute links)
HELP_CENTER_URL=http://localhost:3000

# Optional: HTTP User-Agent when downloading images during sync
# HELP_CENTER_HTTP_USER_AGENT=NotionHelpCenter-ImageSync/1.0

# Optional: Contact page — Crisp live chat
# NEXT_PUBLIC_CRISP_WEBSITE_ID=

# Optional: Contact page — Formspree form (when Crisp not set)
# NEXT_PUBLIC_FORMSPREE_FORM_ID=
